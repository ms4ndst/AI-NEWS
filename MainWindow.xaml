<Window x:Class="AI_NEWS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AI_NEWS"
        mc:Ignorable="d"
        Title="AI-NEWS Reader" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open News Folder..." 
                          Click="OpenFolder_Click"/>
                <Separator/>
                <MenuItem Header="_Refresh File List" 
                          Click="RefreshFiles_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" 
                          Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Theme">
                    <MenuItem Header="Mocha (Dark)" 
                              Click="ThemeMocha_Click"/>
                    <MenuItem Header="Latte (Light)" 
                              Click="ThemeLatte_Click"/>
                    <MenuItem Header="Frappé" 
                              Click="ThemeFrappe_Click"/>
                    <MenuItem Header="Macchiato" 
                              Click="ThemeMacchiato_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About AI-NEWS" 
                          Click="About_Click"/>
            </MenuItem>
        </Menu>
        
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Sidebar - File List -->
        <Border Grid.Column="0" 
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="0,0,1,0"
                CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource CtpMantleBrush}"
                        Padding="12"
                        CornerRadius="0">
                    <TextBlock Text="AI-NEWS Reader" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>
                
                <!-- Folder Path Display -->
                <Border Grid.Row="1" 
                        Background="{DynamicResource CtpSurface0Brush}"
                        Margin="8"
                        Padding="10"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="News Folder" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="FolderPathText" 
                                   Text="..." 
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="40"/>
                        <Button Content="Change Folder" 
                                Click="OpenFolder_Click"
                                Margin="0,8,0,0"
                                Padding="8,4"
                                FontSize="11"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
                
                <!-- File List -->
                <ListBox x:Name="FileListBox" 
                         Grid.Row="2" 
                         Margin="8,0,8,8"
                         SelectionChanged="FileListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Content Header -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource CtpMantleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="0,0,0,1"
                    Padding="20,16"
                    CornerRadius="0">
                <TextBlock x:Name="ContentHeader" 
                           Text="Select a file to read..." 
                           FontSize="22" 
                           FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"/>
            </Border>
            
            <!-- Content Display -->
            <RichTextBox x:Name="ContentRichTextBox"
                         Grid.Row="1"
                         Margin="20,16"
                         Padding="16"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         IsReadOnly="True"
                         IsDocumentEnabled="True"
                         Background="{DynamicResource BackgroundBrush}"
                         Foreground="{DynamicResource TextBrush}"/>
        </Grid>
        </Grid>
    </Grid>
</Window>
